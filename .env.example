# Copy to .env and fill in. .env is gitignored.

# Required for the LLM triage + patch layer. Without it, scans still run and
# return raw findings, just without triage/explanations/patches.
ANTHROPIC_API_KEY=sk-ant-...

# LLM model. Default is claude-fable-5 (GA). claude-mythos-5 is the same model
# but Project-Glasswing-only; use it only if your org is enrolled.
# ANTHROPIC_MODEL=claude-fable-5
# ANTHROPIC_FALLBACK_MODEL=claude-opus-4-8   # server-side fallback on refusals

# Shared bearer token protecting the API. Generate one with:
#   openssl rand -hex 32
# When set, every endpoint except /health requires it. Set the SAME value as
# API_TOKEN in your Vercel project. Leave unset for local dev (auth disabled).
# API_TOKEN=

# Allowed frontend origin(s) for CORS — your Vercel URL in production.
# Comma-separated for multiple. Defaults to http://localhost:3000.
# (Not strictly required when the frontend uses its server-side proxy, but
# harmless to set.)
# FRONTEND_ORIGIN=https://your-app.vercel.app

# Local directory scans (scan a repo/folder already on this machine).
# Only makes sense when the whole stack runs on your machine via docker
# compose — a host path is not reachable from a remote deployment, so LEAVE
# THESE UNSET on the droplet. SCAN_PATH_ROOT optionally confines scannable
# paths to one directory tree.
# ALLOW_LOCAL_SCANS=true
# SCAN_PATH_ROOT=/Users/you/projects

# --- User accounts (optional; without these, sign-in is unavailable but ---
# --- anonymous scanning still works)                                    ---

# GitHub OAuth app for "Continue with GitHub". Create at
# https://github.com/settings/developers with callback URL
#   {FRONTEND_ORIGIN}/api/auth/github/callback
# (http://localhost:3000/api/auth/github/callback for local dev).
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Resend (https://resend.com) sends the email verification codes for
# email+passkey signup. When unset, codes are printed to the api logs instead
# (dev mode). RESEND_FROM must use a domain verified in Resend.
# RESEND_API_KEY=
# RESEND_FROM=VulnScan <auth@yourdomain.com>

# WebAuthn relying-party ID. Defaults to the hostname of the FIRST
# FRONTEND_ORIGIN entry — only set to override that.
# WEBAUTHN_RP_ID=

# Session cookie lifetime.
# SESSION_TTL_DAYS=30

# Optional tuning
# MAX_REPO_MB=500
# SCAN_RATE_LIMIT=10
# SCAN_RATE_WINDOW=3600
