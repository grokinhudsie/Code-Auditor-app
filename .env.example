# Copy to .env and fill in. .env is gitignored.

# Required for the LLM triage + patch layer. Without it, scans still run and
# return raw findings, just without triage/explanations/patches.
ANTHROPIC_API_KEY=sk-ant-...

# LLM model. Default is claude-fable-5 (GA). claude-mythos-5 is the same model
# but Project-Glasswing-only; use it only if your org is enrolled.
# ANTHROPIC_MODEL=claude-fable-5
# ANTHROPIC_FALLBACK_MODEL=claude-opus-4-8   # server-side fallback on refusals

# Allowed frontend origin(s) for CORS — your Vercel URL in production.
# Comma-separated for multiple. Defaults to http://localhost:3000.
# FRONTEND_ORIGIN=https://your-app.vercel.app

# Optional tuning
# MAX_REPO_MB=500
# SCAN_RATE_LIMIT=10
# SCAN_RATE_WINDOW=3600
